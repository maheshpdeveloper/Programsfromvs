#Current Date & Time
from datetime import datetime
now = datetime.now()
print(now)

#Only Date
from datetime import date
today = date.today()
print(today)


#Create Custom Date
from datetime import date
d = date(2025, 4, 10)
print(d)

#Access Date Parts
from datetime import datetime
now = datetime.now()
print(now.year)
print(now.month)
print(now.day)


#Formatting Date (VERY IMPORTANT)
from datetime import datetime

now = datetime.now()

print(now.strftime("%Y-%m-%d"))


